{
    "name": "goldfinch/icon-field",
    "description": "Advanced Icon Field for Silverstripe",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "silverstripe",
        "icon-field",
        "icons-field",
        "silverstripe-icon"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Art Karasev",
            "email": "art.karasev@proton.me"
        }
    ],
    "require": {
        "php": "^8.3",
        "silverstripe/framework": "^6",
        "silverstripe/admin": "^3",
        "goldfinch/silverstripe-jsontext": "dev-master"
    },
    "extra": {
        "expose": [
            "client/dist"
        ]
    },
    "autoload": {
        "psr-4": {
            "Goldfinch\\IconField\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
